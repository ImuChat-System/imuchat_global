{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "📦 Clone All Repos",
      "type": "shell",
      "command": "bash scripts/clone-all-repos.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🌐 Start Web App",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/../web-app"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(.*)$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Starting.*$",
          "endsPattern": "^.*Ready.*$"
        }
      },
      "group": "build"
    },
    {
      "label": "📱 Start Mobile App (Expo)",
      "type": "shell",
      "command": "pnpm start",
      "options": {
        "cwd": "${workspaceFolder}/../mobile-app"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🖥️ Start Desktop App",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/../desktop-app"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "⚙️ Start Platform Core",
      "type": "shell",
      "command": "pnpm dev",
      "options": {
        "cwd": "${workspaceFolder}/../platform-core"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🎨 Build UI Kit",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}/../ui-kit"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🔧 Build Shared Types",
      "type": "shell",
      "command": "pnpm build",
      "options": {
        "cwd": "${workspaceFolder}/../shared-types"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🧪 Run All Tests",
      "type": "shell",
      "command": "bash scripts/run-all-tests.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "test"
    },
    {
      "label": "🔍 Lint All Repos",
      "type": "shell",
      "command": "bash scripts/lint-all.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "🚀 Start Full Stack (Web + API)",
      "dependsOn": [
        "⚙️ Start Platform Core",
        "🌐 Start Web App"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}