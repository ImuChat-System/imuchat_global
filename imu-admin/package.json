{
    "name": "@imuchat/admin",
    "version": "1.0.0",
    "private": true,
    "description": "Admin Panel — Back-office administration dashboard.",
    "author": "ImuChat Team",
    "license": "MIT",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "tsc -b && vite build",
        "build:miniapp": "NODE_ENV=production tsc -b && vite build",
        "deploy:local": "pnpm build:miniapp && mkdir -p ../web-app/public/miniapps/imu-admin && cp -r dist/* ../web-app/public/miniapps/imu-admin/",
        "preview": "vite preview",
        "lint": "eslint . --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
        "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist node_modules"
    },
    "dependencies": {
        "@imuchat/miniapp-sdk": "workspace:*",
        "lucide-react": "^0.400.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "clsx": "^2.1.0",
        "tailwind-merge": "^2.2.0",
        "class-variance-authority": "^0.7.0",
        "@radix-ui/react-slot": "^1.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@vitejs/plugin-react": "^4.3.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "tailwindcss": "^3.4.0",
        "typescript": "~5.5.0",
        "vite": "^5.4.0"
    }
}