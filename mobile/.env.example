# ===========================================
# MOBILE APP - Variables d'environnement
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs

# =================== SUPABASE ===================
# URL et clé anon depuis Supabase Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =================== PLATFORM CORE ===================
# URL du backend platform-core (localhost en dev, URL prod en production)
EXPO_PUBLIC_PLATFORM_CORE_URL=http://localhost:8080

# =================== GOOGLE OAUTH ===================
# Depuis Google Cloud Console > Credentials > OAuth 2.0 Client IDs
# Web client ID (utilisé pour expo-auth-session)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# iOS client ID (Bundle ID: com.imuchat.mobile)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
# Android client ID (SHA-1 fingerprint requis)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com

# =================== STREAM VIDEO ===================
# Depuis getstream.io Dashboard > App > API Key
EXPO_PUBLIC_STREAM_API_KEY=your-stream-api-key

# =================== GIPHY ===================
# Depuis developers.giphy.com > Create an App
EXPO_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# =================== FIREBASE (Push Notifications) ===================
# google-services.json (Android) et GoogleService-Info.plist (iOS)
# doivent être placés à la racine du projet mobile
