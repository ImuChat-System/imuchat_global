# ===========================================
# MOBILE APP - Variables d'environnement
# ===========================================
# Copiez ce fichier en .env et remplissez les valeurs

# =================== SUPABASE ===================
# URL et clé anon depuis Supabase Dashboard > Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =================== PLATFORM CORE — sous-domaines ===================
# Dev : localhost | Prod : sous-domaines imuchat.app
EXPO_PUBLIC_API_URL=http://localhost:8080
EXPO_PUBLIC_WS_URL=ws://localhost:3001
EXPO_PUBLIC_AUTH_URL=http://localhost:8080/auth
EXPO_PUBLIC_MEDIA_URL=http://localhost:8080/api/v1/media
EXPO_PUBLIC_PUSH_URL=http://localhost:8080/api/v1/notifications
# Legacy alias (backward-compat avec les anciens services)
EXPO_PUBLIC_PLATFORM_CORE_URL=http://localhost:8080

# =================== GOOGLE OAUTH ===================
# Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client IDs
#
# Étapes :
# 1. Créer un projet sur https://console.cloud.google.com
# 2. Activer l'API "Google Identity" (ou People API)
# 3. Configurer l'écran de consentement OAuth (External / Testing)
# 4. Créer 3 OAuth Client IDs :
#    - Web application → EXPO_PUBLIC_GOOGLE_CLIENT_ID
#      Authorized redirect URIs : https://auth.expo.io/@your-expo-username/imuchat
#    - iOS → EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID
#      Bundle ID : com.imuchat.mobile
#    - Android → EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID
#      Package name : com.imuchat.mobile
#      SHA-1 fingerprint : keytool -list -v -keystore ~/.android/debug.keystore -alias androiddebugkey -storepass android
EXPO_PUBLIC_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=xxx.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=xxx.apps.googleusercontent.com

# =================== STREAM VIDEO (Appels) ===================
# Depuis https://getstream.io > Dashboard > App > API Key
# Utilisé pour les appels audio/vidéo (DEV-015)
EXPO_PUBLIC_STREAM_API_KEY=your-stream-api-key
# Secret Key (côté serveur uniquement, utilisé par platform-core pour générer les tokens)
STREAM_SECRET_KEY=your-stream-secret-key

# =================== GIPHY ===================
# Depuis https://developers.giphy.com > Create an App > API Key
EXPO_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# =================== MINI-APPS CDN ===================
# URL de base pour charger les bundles mini-apps
# En dev : laisser vide pour le défaut https://miniapps.imuchat.com
EXPO_PUBLIC_MINIAPPS_CDN_URL=https://miniapps.imuchat.com

# =================== FIREBASE (Push Notifications) ===================
# Sender ID depuis Firebase Console > Project Settings > Cloud Messaging
EXPO_PUBLIC_FIREBASE_SENDER_ID=your-firebase-sender-id
# Note : google-services.json (Android) et GoogleService-Info.plist (iOS)
# doivent être placés à la racine du projet mobile

# =================== DEV TOOLS ===================
# Bypass l'authentification en dev (admin auto-connecté)
# EXPO_PUBLIC_DEV_BYPASS_AUTH=true
# EXPO_PUBLIC_DEV_ADMIN_EMAIL=admin@imuchat.dev
# EXPO_PUBLIC_DEV_ADMIN_USERNAME=AdminDev
