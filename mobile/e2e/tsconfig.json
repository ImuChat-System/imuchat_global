{
    "compilerOptions": {
        "types": [
            "detox",
            "jest",
            "node"
        ],
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "moduleResolution": "node",
        "module": "commonjs",
        "target": "ES2022",
        "jsx": "react-native",
        "baseUrl": "..",
        "forceConsistentCasingInFileNames": true,
        "paths": {
            "@/*": [
                "./*"
            ]
        }
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}